# Aiven MySQL (SSL required). Replace USER/PASSWORD/HOST/PORT for your service.
# Example:
# DATABASE_URL="mysql://avnadmin:PASSWORD@mysql-xxxx.a.aivencloud.com:24605/defaultdb?sslaccept=strict"
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/defaultdb?sslaccept=strict"

# Required in production - used to sign JWT session cookies
AUTH_SECRET="change-me-to-a-long-random-string"

# App URL for invite / password-reset links
APP_URL="http://localhost:3000"

# Local file storage (S3-ready interface; local disk fails on Vercel — optional later)
STORAGE_DRIVER="local"
STORAGE_ROOT="./storage"

# Email adapter (console logs in development / Vercel logs)
EMAIL_DRIVER="console"

# Optional: Redis URL (jobs stay in-process until BullMQ adapter is enabled)
# REDIS_URL="redis://localhost:6379"

# Optional: Stripe
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional: AI
# OPENAI_API_KEY="sk-..."
