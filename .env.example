DATABASE_URL="file:./dev.db"

# Required in production - used to sign JWT session cookies
AUTH_SECRET="change-me-to-a-long-random-string"

# App URL for invite links
APP_URL="http://localhost:3000"

# Local file storage (S3-ready interface)
STORAGE_DRIVER="local"
STORAGE_ROOT="./storage"

# Email adapter (console logs in development)
EMAIL_DRIVER="console"

# Optional: Redis URL (jobs stay in-process until BullMQ adapter is enabled)
# REDIS_URL="redis://localhost:6379"

# Optional: Stripe (checkout uses stub plan upgrades without this)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional: AI
# OPENAI_API_KEY="sk-..."

# Postgres / Supabase (Prisma-compatible; swap when ready):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
